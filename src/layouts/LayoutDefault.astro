---
// ABOUTME: Provides the shared document shell and SEO metadata for every page.
// ABOUTME: Centralizes crawler-visible title, favicon, social, and structured-data signals.
import '~/styles/index.css'
// https://sivan.github.io/heti
import '~/styles/heti.min.css'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'
import GoogleAnalytics from '~/components/GoogleAnalytics.astro'
import { SEO } from 'astro-seo'
import { getImage } from 'astro:assets'
import {
  createArticleStructuredData,
  createWebSiteStructuredData,
  normalizeCanonicalUrl
} from '~/utils/seo'
import { SITE_LANGUAGES, withBasePath } from '~/i18n'

interface Props {
  title?: string
  desc?: string
  banner?: ImageMetadata
  keywords?: string[]
  noindex?: boolean
  publishedTime?: Date
  alternates?: Array<{ href: string; hreflang: string }>
}

const props = Astro.props
const themeConfig = Astro.locals.config
const { header } = Astro.locals.config

const pageTitle = props.title ?? themeConfig.title
const title = props.title
  ? `${props.title} - ${themeConfig.title}`
  : `${themeConfig.title} - ${themeConfig.author}`
const desc = props.desc ?? themeConfig.desc
const canonical = normalizeCanonicalUrl(Astro.url)
const noindex = props.noindex ?? false

const image =
  props.banner &&
  (await getImage({
    src: props.banner,
    format: 'jpeg'
  }))
const optimizedImage = new URL(
  image?.src ?? withBasePath('/placeholder.png'),
  Astro.url
).toString()
const alternates = props.alternates ?? []
const defaultAlternate = alternates.find(
  (alternate) => alternate.hreflang === SITE_LANGUAGES.ja.locale
)
const linkAlternates = defaultAlternate
  ? [...alternates, { ...defaultAlternate, hreflang: 'x-default' }]
  : alternates
const structuredData = props.publishedTime
  ? createArticleStructuredData({
      author: themeConfig.author,
      canonical,
      description: desc,
      imageUrl: optimizedImage,
      inLanguage: themeConfig.locale,
      keywords: props.keywords,
      publishedTime: props.publishedTime,
      title: pageTitle
    })
  : createWebSiteStructuredData({
      author: themeConfig.author,
      canonical,
      description: desc,
      inLanguage: themeConfig.locale,
      title: pageTitle
    })
---

<html lang={themeConfig.locale}>
  <head>
    <meta name='viewport' content='width=device-width' />
    <meta name='generator' content={Astro.generator} />
    <link rel="sitemap" href={withBasePath('/sitemap.xml')} />
    <SEO
      charset='utf-8'
      canonical={canonical}
      noindex={noindex}
      title={title}
      description={desc}
      extend={{
        link: [
          {
            rel: 'icon',
            href: withBasePath('/favicon-48x48.png'),
            type: 'image/png',
            sizes: '48x48'
          },
          { rel: 'icon', href: withBasePath('/favicon.svg'), type: 'image/svg+xml' },
          { rel: 'icon', href: withBasePath('/favicon.ico'), sizes: 'any' },
          {
            rel: 'apple-touch-icon',
            href: withBasePath('/apple-touch-icon.png'),
            sizes: '180x180'
          },
          { rel: 'manifest', href: withBasePath('/site.webmanifest') },
          ...linkAlternates.map((alternate) => ({
            rel: 'alternate',
            href: alternate.href,
            hreflang: alternate.hreflang
          }))
        ],
        meta: [
          { name: 'application-name', content: themeConfig.title },
          { name: 'apple-mobile-web-app-title', content: themeConfig.title },
          { property: 'og:site_name', content: themeConfig.title },
          ...(props.keywords?.length
            ? [{ name: 'keywords', content: props.keywords.join(', ') }]
            : []),
          { name: 'twitter:image:src', content: optimizedImage },
          { name: 'twitter:image:alt', content: desc },
          { name: 'twitter:creator', content: header.twitter },
          { name: 'twitter:site', content: header.twitter },
          { name: 'twitter:card', content: 'summary_large_image' },
          { name: 'twitter:title', content: title },
          { name: 'twitter:description', content: desc }
        ]
      }}
      openGraph={{
        basic: {
          title: title,
          type: props.publishedTime ? 'article' : 'website',
          image: optimizedImage,
          url: canonical
        }
      }}
    />
    <script
      type='application/ld+json'
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    <GoogleAnalytics />
  </head>
  <body>
    <div
      un-max-lg='animate-fadein-down'
      un-lg='flex flex-row-reverse justify-between gap-4 px-8 mx-auto max-w-6xl'
      class='site-shell container contain-layout m-a'
    >
      <div
        un-lg='sticky top-0 h-screen py-20 animate-fadein-left gap-8'
        un-lg:flex='~ col justify-between items-start gap-4'
        class='site-sidebar p-7.5'
      >
        <Header />
        <Footer class='desktop-site-footer' />
      </div>
      <main un-lg='py-20 min-w-xl animate-fadein-down' class='site-main p-7.5'>
        <slot />
      </main>
    </div>
  </body>
</html>
