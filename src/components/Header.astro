---
import type { HTMLAttributes } from 'astro/types'
import {
  getLanguageFromLocale,
  getLanguageSwitcherLinks
} from '~/i18n'

type Props = HTMLAttributes<'header'>

const { ...attrs } = Astro.props

const { title, author, socials, navs } = Astro.locals.config

const { translate: t } = Astro.locals
const currentLanguage = getLanguageFromLocale(Astro.locals.config.locale)
const languageLinks = getLanguageSwitcherLinks(Astro.url.pathname)
---

<header
  un-lg='grow-1 justify-between items-start'
  un-flex='~ col gap-2.5'
  class='site-header text-center'
  {...attrs}
>
  <hgroup
    un-hover:lg='bg-foreground color-background pt-3.75 pb-8.75 '
    un-lg=' write-vertical-right items-start px-2.5 pb-12 b-l-2px b-l-foreground-solid text-left'
    un-flex='~ col gap-2.5'
    class='site-brand cursor-pointer transition-[padding,background] duration-800 ease-in-out'
  >
    <a class='normal' href='/web-nikki/'>
      <h3 class='site-brand-author text-5 font-extrabold font-serif'>{author}</h3>
      <h1 class='site-brand-title text-8 font-extrabold font-serif'>{title}</h1>
    </a>
  </hgroup>

  <nav class='site-nav text-center font-bold' un-flex='~ col gap-2'>
    <ul
      un-lg='flex-col items-start text-4'
      class='primary-nav text-3.5'
      un-flex='~ row gap-2 justify-center'
    >
      {
        navs.map((nav) => (
          <li>
            <a href={nav.href}>{t(nav.name)}</a>
          </li>
        ))
      }
    </ul>
    <ul class='social-nav' un-flex='~ row gap-1 justify-center'>
      {
        socials.map((soc) => (
          <li>
            <a
              href={soc.href}
              target='_blank'
              title={soc.name}
              class={`icon i-mdi-${soc.name}`}
            />
          </li>
        ))
      }
    </ul>
    <ul
      aria-label={t('language')}
      un-lg='flex-col items-start'
      class='language-nav text-3'
      un-flex='~ row gap-2 justify-center'
    >
      {
        languageLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={link.language === currentLanguage ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
