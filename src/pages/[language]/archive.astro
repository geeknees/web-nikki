---
// ABOUTME: Localized archive page grouping translated posts by publication year.
// ABOUTME: Keeps English and Chinese archives filtered to their own language.

import ArchiveList from '~/components/ArchiveList.astro'
import { getPosts } from '~/utils'
import { TRANSLATED_LANGUAGES } from '~/i18n'

export function getStaticPaths() {
  return TRANSLATED_LANGUAGES.map((language) => ({
    params: { language },
    props: { language }
  }))
}

const { language } = Astro.props
const posts = await getPosts({ language })
---

<ArchiveList posts={posts} />
