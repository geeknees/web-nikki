---
// ABOUTME: Localized paginated post index for translated articles.
// ABOUTME: Keeps pagination URLs language-prefixed for English and Chinese readers.

import PostListPage from '~/components/PostListPage.astro'
import { getPosts } from '~/utils'
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro'
import { TRANSLATED_LANGUAGES } from '~/i18n'

export const getStaticPaths = (async ({ paginate }) => {
  const paths = []

  for (const language of TRANSLATED_LANGUAGES) {
    const posts = await getPosts({ language })
    paths.push(...paginate(posts, { params: { language }, pageSize: 5 }))
  }

  return paths
}) satisfies GetStaticPaths

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { page } = Astro.props
const { language } = Astro.params
---

<PostListPage page={page} language={language} />
