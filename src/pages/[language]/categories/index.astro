---
// ABOUTME: Localized category index for translated post collections.
// ABOUTME: Counts categories only from posts in the current language.

import CategoryIndex from '~/components/CategoryIndex.astro'
import { getCategories } from '~/utils/index'
import { TRANSLATED_LANGUAGES } from '~/i18n'

export function getStaticPaths() {
  return TRANSLATED_LANGUAGES.map((language) => ({
    params: { language },
    props: { language }
  }))
}

const { language } = Astro.props

const categories = await getCategories(language)
---

<CategoryIndex categories={categories} language={language} />
