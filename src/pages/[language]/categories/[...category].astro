---
// ABOUTME: Localized category detail pages for translated post collections.
// ABOUTME: Generates prefixed English and Chinese category URLs with language-filtered posts.

import CategoryPostList from '~/components/CategoryPostList.astro'
import { getCategories, getPathFromCategory } from '~/utils'
import { THEME_CONFIG } from '~/theme.config'
import { TRANSLATED_LANGUAGES } from '~/i18n'

export async function getStaticPaths() {
  const paths = []

  for (const language of TRANSLATED_LANGUAGES) {
    const categories = await getCategories(language)
    paths.push(
      ...Array.from(categories).map(([key, value]) => {
        const path = getPathFromCategory(key, THEME_CONFIG.category_map)
        return {
          params: { language, category: path, name: key },
          props: { categoryName: key, posts: value }
        }
      })
    )
  }

  return paths
}

const { categoryName, posts } = Astro.props
---

<CategoryPostList categoryName={categoryName} posts={posts} />
