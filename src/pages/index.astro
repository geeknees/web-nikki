---
import LayoutDefault from '~/layouts/LayoutDefault.astro'
import Post from '~/components/Post.astro'
import { getPosts, getPostDescription, getKeywordSummary } from '~/utils'
import Pagination from '~/components/Pagination.astro'
import ListSection from '~/components/ListSection.astro'
import ListItem from '~/components/ListItem.astro'
import { getHomepageCategorySelections } from '~/content/post-categories'
import { DEFAULT_LANGUAGE, getPostPath } from '~/i18n'

const allPosts = await getPosts({ language: DEFAULT_LANGUAGE })
const posts = allPosts.slice(0, 5)
const homepageCategorySelections = getHomepageCategorySelections(
  allPosts,
  posts.map((post) => post.id)
)

const { translate: t } = Astro.locals
---

<LayoutDefault>
  <section contain-layout un-flex='~ col gap-7.5'>
    {
      posts.map((post) => (
        <Post post={post}>
          <p class='line-clamp-4'>{getPostDescription(post)}</p>
        </Post>
      ))
    }
    <ListSection title={t('read_by_topic')}>
      {
        homepageCategorySelections.map(({ category, post }) => (
          <ListItem
            title={post.data.title}
            href={getPostPath(post)}
            description={`${category} — ${getKeywordSummary(post)}`}
          />
        ))
      }
    </ListSection>
    <Pagination
      showLeft={false}
      showPageCount={false}
      rightTitle={t('all_posts')}
      rightUrl={'posts/page/1'}
    />
  </section>
</LayoutDefault>
