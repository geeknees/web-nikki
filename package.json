{
  "name": "web-nikki",
  "type": "module",
  "version": "1.0.0",
  "repository": "https://github.com/geeknees/web-nikki",
  "scripts": {
    "dev": "astro check && astro dev",
    "preview": "astro preview",
    "build": "astro check && astro build",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:unit": "node --test --experimental-strip-types tests/unit/*.test.ts",
    "test:integration": "node --test --experimental-strip-types tests/integration/*.test.ts",
