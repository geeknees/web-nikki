    "@github/clipboard-copy-element": "^1.3.0",
    "astro": "^7.0.6",
    "astro-embed": "^0.7.2",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^0.8.4",
    "markdown-it": "^14.0.0",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.11.0",
    "typescript": "^5.5.4",
    "@astrojs/markdown-remark": "^7.2.1"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.1.64",
